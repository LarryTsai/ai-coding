VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_VERSION=0.1.0

# 設為 false 可略過 AAD 登入（credentials 保留但不啟用），預設 true
VITE_USE_AAD=true

# Azure AD / Entra ID SPA app registration
VITE_AAD_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_AAD_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AAD_REDIRECT_URI=http://localhost:5173

# Backend API app registration. If omitted, the frontend app client id is used.
VITE_AAD_API_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AAD_SCOPES=api://00000000-0000-0000-0000-000000000000/access_as_user
